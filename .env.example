# 교움 백엔드 환경 변수 예시.
# 이 파일을 `backend/.env`로 복사한 뒤 실제 값을 채워 사용하세요.

# SQLite 파일 경로(기본값 사용 시 미설정 가능).
# GYOUM_DATABASE_URL=sqlite:///gyoum.db
#
# Docker 환경에서는 docker-compose.yml의 environment 섹션에서
# sqlite:////app/data/gyoum.db 로 자동 설정되므로 .env에서는 미설정 가능.

# 서울 열린데이터 광장 — 실시간 도착 정보 API 키.
# https://data.seoul.go.kr/  → 서비스 신청  → 인증 키 발급
# GYOUM_SEOUL_OPEN_API_KEY=
# 이전 브랜치 호환 이름. GYOUM_SEOUL_OPEN_API_KEY가 비어 있으면 이 값을 사용합니다.
# GYOUM_SUBWAY_ARRIVAL_API_KEY=

# Firebase Cloud Messaging 서비스 계정 JSON 파일 경로 (절대 경로 권장).
# Firebase 콘솔 > 프로젝트 설정 > 서비스 계정 > "새 비공개 키 생성"으로 다운로드.
# 미설정 시 푸시 발송은 no-op로 폴백하고 WebSocket으로만 실시간 동작.
# GYOUM_FIREBASE_CREDENTIALS_PATH=/absolute/path/to/firebase-service-account.json

# 추가 허용 Origin (콤마 구분 X — JSON array 형태 또는 환경 한정 시 미설정).
# GYOUM_ALLOWED_ORIGINS=["http://localhost:8081"]
